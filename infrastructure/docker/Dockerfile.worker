# syntax=docker/dockerfile:1
# Same build as API — different process entrypoint for BullMQ workers.

FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@11.11.0 --activate
WORKDIR /app
ENV CI=true

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json apps/api/
COPY apps/web/package.json apps/web/
COPY packages/shared-types/package.json packages/shared-types/
COPY packages/config/package.json packages/config/
RUN pnpm install --frozen-lockfile
RUN pnpm approve-builds --all

FROM deps AS build
COPY prisma prisma
COPY packages packages
COPY apps/api apps/api
RUN pnpm db:generate
RUN pnpm --filter @project-braids/shared-types build
RUN pnpm --filter @project-braids/api build
RUN pnpm --filter @project-braids/api deploy --prod --legacy /app/deploy
RUN rm -rf /app/deploy/dist \
  && cp -r /app/apps/api/dist /app/deploy/dist \
  && cp -r /app/prisma /app/deploy/prisma \
  && SRC="$(find /app/node_modules/.pnpm -type d -path '*/node_modules/.prisma' | head -1)" \
  && DEST_PARENT="$(find /app/deploy/node_modules/.pnpm -type d -path '*/@prisma+client@*/node_modules' | head -1)" \
  && test -n "$SRC" && test -n "$DEST_PARENT" \
  && rm -rf "$DEST_PARENT/.prisma" \
  && cp -a "$SRC" "$DEST_PARENT/.prisma"

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ARG GIT_SHA=unknown
ENV GIT_SHA=${GIT_SHA}

COPY --from=build /app/deploy ./

CMD ["node", "dist/worker.js"]
