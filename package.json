{
  "name": "project-braids",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "worker:dev": "pnpm --filter @project-braids/api worker:dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdc,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,mdc,yml,yaml}\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "infra:up": "bash scripts/infra-up.sh",
    "infra:down": "bash scripts/infra-down.sh",
    "mvp:demo": "tsx scripts/mvp-demo.ts",
    "ops:check-migrations": "bash scripts/ops/check-migrations.sh",
    "ops:migrate-deploy": "bash scripts/ops/migrate-deploy.sh",
    "ops:kill-switch-drill": "bash scripts/ops/kill-switch-drill.sh",
    "ops:rollback": "bash scripts/ops/rollback.sh",
    "ops:smoke-staging": "bash scripts/ops/smoke-staging.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@prisma/client": "^6.9.0",
    "@project-braids/shared-types": "workspace:*",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "pnpm exec eslint --fix --max-warnings 0"
    ],
    "*.{json,md,mdc,yml,yaml}": [
      "pnpm exec prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
