# API
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://braids:braids@localhost:5432/braids_dev
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
PLATFORM_DISPLAY_NAME=Project Braids

# Auth
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30
WEB_APP_URL=http://localhost:3000

# OAuth (optional until configured)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

# Optional observability
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_DISPLAY_NAME=Project Braids
