# API
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://braids:braids@localhost:5432/braids_dev
# No Docker? Run `pnpm infra:up` and use Prisma Dev instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:51214/braids_dev?sslmode=disable
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
PLATFORM_DISPLAY_NAME=Project Braids

# Auth
JWT_SECRET=local-dev-jwt-secret-min-32-chars-ok
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30
WEB_APP_URL=http://localhost:3000
BOOKING_HOLD_TTL_MINUTES=15
PLATFORM_TIMEZONE=Europe/London
AVAILABILITY_SLOT_INTERVAL_MINUTES=15
AVAILABILITY_MAX_DAYS=14

# OAuth (optional until configured)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=

# Optional observability
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_DISPLAY_NAME=Project Braids
