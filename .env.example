# Project Braids — local development environment
# Copy this file to `.env` at the repo root (never commit `.env`).
# Per-app references: apps/api/.env.example, apps/web/.env.example

# API
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DATABASE_URL=postgresql://braids:braids@localhost:5432/braids_dev
# No Docker? Run `pnpm infra:up` and use Prisma Dev instead:
# DATABASE_URL=postgresql://postgres:postgres@localhost:51214/braids_dev?sslmode=disable&pgbouncer=true
REDIS_URL=redis://localhost:6379
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000
PLATFORM_DISPLAY_NAME=Project Braids

# Auth
JWT_SECRET=local-dev-jwt-secret-min-32-chars-ok
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30
WEB_APP_URL=http://localhost:3000
BOOKING_HOLD_TTL_MINUTES=15
PLATFORM_TIMEZONE=Europe/London
AVAILABILITY_SLOT_INTERVAL_MINUTES=15
AVAILABILITY_MAX_DAYS=14

# Stripe (optional in local dev — mock provider used when unset)
# For real deposits see docs/STRIPE_LIVE_SETUP.md
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_RETURN_URL=http://localhost:3000/stylist/payments
# STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/stylist/payments

# Twilio SMS (optional in local dev — console provider used when unset)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+447...
# API_PUBLIC_URL=http://localhost:3001

# Anthropic Claude (optional in local dev — mock provider used when unset)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
# AI_RECEPTIONIST_ENABLED=true
# AI_CONFIDENCE_THRESHOLD=0.8

# OAuth (optional until configured)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALENDAR_WEBHOOK_SECRET=
# Same client ID for the web Calendar connect button:
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# APPLE_CLIENT_ID=

# Optional observability
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# Web (Next.js) — see apps/web/.env.example
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_DISPLAY_NAME=Project Braids
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
