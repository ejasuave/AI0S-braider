generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Chapter 3+ will expand this schema. Minimal bootstrap model for migration wiring.
model SchemaVersion {
  id        String   @id @default(uuid()) @db.Uuid
  label     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("schema_versions")
}

/// Idempotency ledger for inbound webhooks (Ch.2.6, Ch.9.4).
model ProcessedWebhookEvent {
  eventId     String   @id @map("event_id")
  source      String
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz(6)

  @@index([source, processedAt])
  @@map("processed_webhook_events")
}

/// Audit trail for example background job (Ch.2.5 demonstration).
model ExampleJobRun {
  id          String    @id @default(uuid()) @db.Uuid
  bullJobId   String    @unique @map("bull_job_id")
  status      String
  result      String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)

  @@map("example_job_runs")
}

// --- Identity (Chapter 3) ---

enum UserRole {
  stylist_owner
  stylist_staff
  client
  admin

  @@map("user_role")
}

enum OtpPurpose {
  phone_verify
  login
  password_reset

  @@map("otp_purpose")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  role            UserRole
  phoneNumber     String    @unique @map("phone_number")
  email           String?   @unique
  passwordHash    String?   @map("password_hash")
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deactivatedAt   DateTime? @map("deactivated_at") @db.Timestamptz(6)

  sessions              Session[]
  oauthAccounts         OAuthAccount[]
  otpChallenges         OtpChallenge[]
  passwordResetTokens   PasswordResetToken[]
  accountRecoveryRequests AccountRecoveryRequest[]
  phoneChangeRequests   PhoneNumberChangeRequest[] @relation("PhoneChangeUser")
  phoneChangesResolved  PhoneNumberChangeRequest[] @relation("PhoneChangeResolver")
  ownedBusiness       Business?                  @relation("BusinessOwner")
  businessStaff       BusinessStaff[]
  adminImpersonations ImpersonationSession[]     @relation("ImpersonationAdmin")
  targetImpersonations ImpersonationSession[]    @relation("ImpersonationTarget")
  stylistMembership     StylistMembership?
  stylistProfile           StylistProfile?
  notifications            Notification[]
  notificationPreferences  NotificationPreference?
  optOutAuditEvents        OptOutAuditLog[]
  clientProfile            ClientProfile?
  savedStylists            SavedStylist[]         @relation("SavedStylistClient")

  @@index([role])
  @@map("users")
}

/// Links stylist_staff users to a stylist tenant. Expanded in Ch.4.3 (V2).
model StylistMembership {
  id        String   @id @default(uuid()) @db.Uuid
  stylistId String   @map("stylist_id") @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stylistId])
  @@map("stylist_memberships")
}

// --- Roles & permissions (Chapter 4) ---

enum ServiceVenueMode {
  remote
  stylist_location
  come_to_client

  @@map("service_venue_mode")
}

model Business {
  id                  String           @id @default(uuid()) @db.Uuid
  ownerUserId         String           @unique @map("owner_user_id") @db.Uuid
  businessName        String           @default("") @map("business_name")
  bio                 String?
  locationLat         Decimal?         @map("location_lat") @db.Decimal(10, 7)
  locationLng         Decimal?         @map("location_lng") @db.Decimal(10, 7)
  locationLabel       String?          @map("location_label")
  serviceAreaRadiusKm Decimal?         @map("service_area_radius_km") @db.Decimal(6, 2)
  /// Venue options the stylist offers (client chooses one per booking).
  offersStylistLocation Boolean          @default(true) @map("offers_stylist_location")
  offersComeToClient    Boolean          @default(false) @map("offers_come_to_client")
  offersRemote          Boolean          @default(false) @map("offers_remote")
  /// Full workplace / studio address — shown to clients only after confirmation.
  workplaceAddress    String?          @map("workplace_address")
  /// Extra amount (GBP) added when the client chooses come_to_client.
  homeVisitSurcharge  Decimal?         @map("home_visit_surcharge") @db.Decimal(10, 2)
  onboardingStatus    OnboardingStatus @default(in_progress) @map("onboarding_status")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  owner                User                  @relation("BusinessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  staff                BusinessStaff[]
  profile              StylistProfile?
  policy               BusinessPolicy?
  workingHours         WorkingHour[]
  scheduleExceptions   ScheduleException[]
  portfolioItems       PortfolioItem[]
  serviceOfferings     ServiceOffering[]
  instagramConnection  InstagramConnection?
  calendarConnection CalendarConnection?
  calendarConflicts    CalendarConflict[]
  externalCalendarLinks ExternalCalendarLink[]
  paymentAccount       PaymentAccount?

  @@map("businesses")
}

model BusinessStaff {
  id           String    @id @default(uuid()) @db.Uuid
  businessId   String    @map("business_id") @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  inviteeEmail String?   @map("invitee_email")
  inviteePhone String?   @map("invitee_phone")
  permissions  Json
  invitedAt    DateTime  @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt   DateTime? @map("accepted_at") @db.Timestamptz(6)
  removedAt    DateTime? @map("removed_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, removedAt])
  @@index([userId])
  @@map("business_staff")
}

model ImpersonationSession {
  id            String    @id @default(uuid()) @db.Uuid
  adminUserId   String    @map("admin_user_id") @db.Uuid
  targetUserId  String    @map("target_user_id") @db.Uuid
  reason        String
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt       DateTime? @map("ended_at") @db.Timestamptz(6)
  createdFromIp String    @map("created_from_ip")

  admin  User @relation("ImpersonationAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)
  target User @relation("ImpersonationTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, startedAt])
  @@index([targetUserId])
  @@map("impersonation_sessions")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  familyId         String    @map("family_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  deviceMetadata   Json?     @map("device_metadata")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("sessions")
}

model OtpChallenge {
  id          String     @id @default(uuid()) @db.Uuid
  phoneNumber String     @map("phone_number")
  purpose     OtpPurpose
  codeHash    String     @map("code_hash")
  expiresAt   DateTime   @map("expires_at") @db.Timestamptz(6)
  consumedAt  DateTime?  @map("consumed_at") @db.Timestamptz(6)
  attempts    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneNumber, purpose, createdAt])
  @@map("otp_challenges")
}

enum PhoneChangeStatus {
  pending
  approved
  rejected

  @@map("phone_change_status")
}

model OAuthAccount {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String
  providerAccountId String   @map("provider_account_id")
  accessTokenEnc    String?  @map("access_token_enc")
  refreshTokenEnc   String?  @map("refresh_token_enc")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("oauth_accounts")
}

model PhoneNumberChangeRequest {
  id                  String            @id @default(uuid()) @db.Uuid
  userId              String            @map("user_id") @db.Uuid
  requestedPhoneNumber String           @map("requested_phone_number")
  status              PhoneChangeStatus @default(pending)
  requestedAt         DateTime          @default(now()) @map("requested_at") @db.Timestamptz(6)
  resolvedAt          DateTime?         @map("resolved_at") @db.Timestamptz(6)
  resolvedById        String?           @map("resolved_by") @db.Uuid

  user       User  @relation("PhoneChangeUser", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("PhoneChangeResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("phone_number_change_requests")
}

model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model AccountRecoveryRequest {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  email       String
  phoneNumber String?  @map("phone_number")
  reason      String
  status      String   @default("pending")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([status])
  @@map("account_recovery_requests")
}

// --- Stylist profile (Chapter 6) ---

enum DepositType {
  flat
  percentage

  @@map("deposit_type")
}

enum NoShowFeeType {
  forfeit_deposit
  flat_fee
  no_fee

  @@map("no_show_fee_type")
}

enum OnboardingStatus {
  in_progress
  complete

  @@map("onboarding_status")
}

enum PortfolioSource {
  manual
  instagram

  @@map("portfolio_source")
}

model BusinessPolicy {
  businessId              String        @id @map("business_id") @db.Uuid
  depositType             DepositType   @map("deposit_type")
  depositValue            Decimal       @map("deposit_value") @db.Decimal(10, 2)
  cancellationWindowHours Int           @map("cancellation_window_hours")
  noShowFeeType           NoShowFeeType @map("no_show_fee_type")
  noShowFeeValue          Decimal?      @map("no_show_fee_value") @db.Decimal(10, 2)
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_policies")
}

model WorkingHour {
  id         String  @id @default(uuid()) @db.Uuid
  businessId String  @map("business_id") @db.Uuid
  dayOfWeek  Int     @map("day_of_week")
  startTime  String  @map("start_time")
  endTime    String  @map("end_time")
  isActive   Boolean @default(true) @map("is_active")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek])
  @@map("working_hours")
}

model ScheduleException {
  id                String   @id @default(uuid()) @db.Uuid
  businessId        String   @map("business_id") @db.Uuid
  date              DateTime @db.Date
  isClosed          Boolean  @default(false) @map("is_closed")
  overrideStartTime String?  @map("override_start_time")
  overrideEndTime   String?  @map("override_end_time")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, date])
  @@map("schedule_exceptions")
}

model InstagramConnection {
  businessId      String   @id @map("business_id") @db.Uuid
  instagramUserId String   @map("instagram_user_id")
  accessTokenEnc  String   @map("access_token_enc")
  tokenExpiresAt  DateTime @map("token_expires_at") @db.Timestamptz(6)
  connectedAt     DateTime @default(now()) @map("connected_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("instagram_connections")
}

model StylistProfile {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @unique @map("user_id") @db.Uuid
  businessId          String?          @unique @map("business_id") @db.Uuid
  businessName        String           @default("") @map("business_name")
  bio                 String?
  locationArea        String?          @map("location_area")
  serviceAreaRadiusKm Decimal?         @map("service_area_radius_km") @db.Decimal(6, 2)
  cancellationPolicy  Json?            @map("cancellation_policy")
  depositPolicy       Json?            @map("deposit_policy")
  workingHours        Json?            @map("working_hours")
  bufferMinutes            Int              @default(15) @map("buffer_minutes")
  requireStylistApproval   Boolean          @default(false) @map("require_stylist_approval")
  onboardingStatus         OnboardingStatus @default(in_progress) @map("onboarding_status")
  directoryVisible    Boolean          @default(false) @map("directory_visible")
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  business         Business?         @relation(fields: [businessId], references: [id], onDelete: SetNull)
  portfolioItems   PortfolioItem[]
  serviceOfferings ServiceOffering[]
  conversations    Conversation[]
  savedByClients   SavedStylist[]

  smsBookingNumber String? @unique @map("sms_booking_number")

  @@map("stylist_profiles")
}

model PortfolioItem {
  id           String          @id @default(uuid()) @db.Uuid
  businessId   String          @map("business_id") @db.Uuid
  stylistId    String          @map("stylist_id") @db.Uuid
  imageUrl     String          @map("image_url")
  storageKey   String?         @map("storage_key")
  source       PortfolioSource @default(manual)
  displayOrder Int             @default(0) @map("display_order")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  business Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stylist  StylistProfile @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  @@index([businessId, displayOrder])
  @@index([stylistId, displayOrder])
  @@map("portfolio_items")
}

model ServiceOffering {
  id                       String   @id @default(uuid()) @db.Uuid
  businessId               String   @map("business_id") @db.Uuid
  stylistId                String   @map("stylist_id") @db.Uuid
  styleCategoryId          String?  @map("style_category_id") @db.Uuid
  styleName                String   @map("style_name")
  sizeTier                 String?  @map("size_tier")
  lengthTier               String?  @map("length_tier")
  basePrice                Decimal  @map("base_price") @db.Decimal(10, 2)
  estimatedDurationMinutes Int      @map("estimated_duration_minutes")
  hairIncluded             Boolean  @default(false) @map("hair_included")
  isCustomStyle            Boolean  @default(false) @map("is_custom_style")
  active                   Boolean  @default(true)
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stylist       StylistProfile @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  styleCategory StyleCategory? @relation(fields: [styleCategoryId], references: [id], onDelete: SetNull)

  @@index([businessId, active])
  @@index([stylistId, active])
  @@index([stylistId, styleName])
  @@map("service_offerings")
}

/// Seeded reference taxonomy for guided pricing setup (Ch.6.4).
model StyleCategory {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  slug        String  @unique
  isCustom    Boolean @default(false) @map("is_custom")
  sizeTiers   Json    @default("[]") @map("size_tiers")
  lengthTiers Json    @default("[]") @map("length_tiers")
  sortOrder   Int     @default(0) @map("sort_order")

  offerings ServiceOffering[]

  @@map("style_categories")
}

// --- Booking engine (Chapter 7) ---

enum BookingStatus {
  held
  confirmed
  completed
  cancelled
  no_show

  @@map("booking_status")
}

enum BookingDepositStatus {
  pending
  paid
  refunded
  forfeited

  @@map("booking_deposit_status")
}

enum BookingSource {
  ai_agent
  dashboard_manual
  client_direct

  @@map("booking_source")
}

model Booking {
  id                     String               @id @default(uuid()) @db.Uuid
  stylistId              String               @map("stylist_id") @db.Uuid
  clientId               String?              @map("client_id") @db.Uuid
  serviceOfferingId      String?              @map("service_offering_id") @db.Uuid
  status                 BookingStatus        @default(held)
  startTime              DateTime             @map("start_time") @db.Timestamptz(6)
  endTime                DateTime             @map("end_time") @db.Timestamptz(6)
  agreedPrice            Decimal              @map("agreed_price") @db.Decimal(10, 2)
  agreedDurationMinutes  Int                  @map("agreed_duration_minutes")
  depositAmount          Decimal              @map("deposit_amount") @db.Decimal(10, 2)
  depositStatus          BookingDepositStatus @default(pending) @map("deposit_status")
  holdExpiresAt          DateTime?            @map("hold_expires_at") @db.Timestamptz(6)
  source                 BookingSource
  /// Snapshot of business venue mode at booking time.
  serviceVenueMode       ServiceVenueMode     @default(stylist_location) @map("service_venue_mode")
  /// Snapshot: workplace address or client visit address (mode-dependent).
  venueAddress           String?              @map("venue_address")
  homeVisitSurcharge     Decimal              @default(0) @map("home_visit_surcharge") @db.Decimal(10, 2)
  /// Snapshot of client display name at booking time.
  clientDisplayName      String?              @map("client_display_name")
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  cancelledAt            DateTime?            @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason     String?              @map("cancellation_reason")
  policySnapshot         Json?                @map("policy_snapshot")
  stylistApprovedAt      DateTime?            @map("stylist_approved_at") @db.Timestamptz(6)

  notifications      Notification[]
  calendarConflicts  CalendarConflict[]
  externalCalendarLinks ExternalCalendarLink[]
  payment            Payment?
  disputeEvidencePackages DisputeEvidencePackage[]

  @@index([stylistId, status, startTime, endTime])
  @@index([clientId, status])
  @@index([holdExpiresAt])
  @@map("bookings")
}

enum CalendarConflictResolution {
  kept_platform_booking
  kept_external_event
  manual_other

  @@map("calendar_conflict_resolution")
}

model CalendarConflict {
  id              String                      @id @default(uuid()) @db.Uuid
  businessId      String                      @map("business_id") @db.Uuid
  bookingId       String?                     @map("booking_id") @db.Uuid
  externalEventId String                      @map("external_event_id")
  detectedAt      DateTime                    @default(now()) @map("detected_at") @db.Timestamptz(6)
  resolvedAt      DateTime?                   @map("resolved_at") @db.Timestamptz(6)
  resolution      CalendarConflictResolution? @map("resolution")

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([businessId, resolvedAt])
  @@map("calendar_conflicts")
}

enum ExternalCalendarProvider {
  google

  @@map("external_calendar_provider")
}

enum ExternalCalendarSyncStatus {
  synced
  pending
  failed

  @@map("external_calendar_sync_status")
}

/// Ch.8.2 — Google Calendar connection per business (independent of login OAuth).
model CalendarConnection {
  businessId            String                   @id @map("business_id") @db.Uuid
  provider              ExternalCalendarProvider @default(google)
  refreshTokenEnc       String                   @map("refresh_token_enc")
  accessTokenEnc        String?                  @map("access_token_enc")
  tokenExpiresAt        DateTime?                @map("token_expires_at") @db.Timestamptz(6)
  calendarId            String                   @default("primary") @map("calendar_id")
  channelId             String?                  @map("channel_id")
  channelResourceId     String?                  @map("channel_resource_id")
  subscriptionExpiresAt DateTime?                @map("subscription_expires_at") @db.Timestamptz(6)
  connectedAt           DateTime                 @default(now()) @map("connected_at") @db.Timestamptz(6)
  updatedAt             DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("calendar_connections")
}

/// Ch.8.2 — maps platform bookings to external calendar events.
model ExternalCalendarLink {
  id              String                     @id @default(uuid()) @db.Uuid
  businessId      String                     @map("business_id") @db.Uuid
  provider        ExternalCalendarProvider   @default(google)
  externalEventId String                     @map("external_event_id")
  bookingId       String?                    @map("booking_id") @db.Uuid
  syncStatus      ExternalCalendarSyncStatus @default(pending) @map("sync_status")
  createdAt       DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@unique([businessId, provider, externalEventId])
  @@index([businessId, bookingId])
  @@map("external_calendar_links")
}

// --- Payments (Chapter 9) ---

enum PaymentOnboardingStatus {
  not_started
  in_progress
  complete
  restricted

  @@map("payment_onboarding_status")
}

model PaymentAccount {
  businessId             String                  @id @map("business_id") @db.Uuid
  stripeConnectAccountId String                  @unique @map("stripe_connect_account_id")
  onboardingStatus       PaymentOnboardingStatus @default(not_started) @map("onboarding_status")
  chargesEnabled         Boolean                 @default(false) @map("charges_enabled")
  payoutsEnabled         Boolean                 @default(false) @map("payouts_enabled")
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("payment_accounts")
}

enum PaymentStatus {
  pending
  captured
  refunded
  forfeited
  failed

  @@map("payment_status")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  bookingId             String        @unique @map("booking_id") @db.Uuid
  stripePaymentIntentId String        @unique @map("stripe_payment_intent_id")
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("gbp")
  status                PaymentStatus @default(pending)
  refundedAmount        Decimal?      @map("refunded_amount") @db.Decimal(10, 2)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  capturedAt            DateTime?     @map("captured_at") @db.Timestamptz(6)

  booking                 Booking                  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  disputeEvidencePackages DisputeEvidencePackage[]

  @@map("payments")
}

model DisputeEvidencePackage {
  id                  String    @id @default(uuid()) @db.Uuid
  paymentId           String    @map("payment_id") @db.Uuid
  bookingId           String    @map("booking_id") @db.Uuid
  assembledAt         DateTime  @default(now()) @map("assembled_at") @db.Timestamptz(6)
  submittedToStripeAt DateTime? @map("submitted_to_stripe_at") @db.Timestamptz(6)
  evidenceData        Json      @map("evidence_data")
  isComplete          Boolean   @default(false) @map("is_complete")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("dispute_evidence_packages")
}

// --- Messaging (Chapter 11) ---

enum ConversationChannel {
  sms
  whatsapp
  web

  @@map("conversation_channel")
}

enum ConversationStatus {
  active
  escalated
  resolved
  abandoned

  @@map("conversation_status")
}

enum MessageSender {
  client
  ai
  stylist
  system

  @@map("message_sender")
}

enum MessageDeliveryStatus {
  pending
  sent
  delivered
  failed
  undelivered

  @@map("message_delivery_status")
}

model Conversation {
  id            String              @id @default(uuid()) @db.Uuid
  stylistId     String              @map("stylist_id") @db.Uuid
  clientId      String              @map("client_id") @db.Uuid
  channel       ConversationChannel
  status        ConversationStatus  @default(active)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  lastMessageAt DateTime            @default(now()) @map("last_message_at") @db.Timestamptz(6)

  stylist     StylistProfile @relation(fields: [stylistId], references: [id], onDelete: Cascade)
  messages    Message[]
  escalations Escalation[]

  @@index([stylistId, status, lastMessageAt])
  @@index([clientId, lastMessageAt])
  @@index([stylistId, clientId, channel, status])
  @@map("conversations")
}

model Message {
  id                String                 @id @default(uuid()) @db.Uuid
  conversationId    String                 @map("conversation_id") @db.Uuid
  sender            MessageSender
  content           String
  structuredOutput  Json?                  @map("structured_output")
  providerMessageId String?                @unique @map("provider_message_id")
  deliveryStatus    MessageDeliveryStatus? @map("delivery_status")
  createdAt         DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Escalation {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  reason         String
  modelConfidence Float?   @map("model_confidence")
  modelNextAction String?  @map("model_next_action")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt     DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedById   String?   @map("resolved_by_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("escalations")
}

// --- Notifications (Chapter 12) ---

enum NotificationType {
  reminder_48h
  reminder_2h
  confirmation
  cancellation
  no_show_notice

  @@map("notification_type")
}

enum NotificationStatus {
  scheduled
  sent
  failed
  skipped
  cancelled

  @@map("notification_status")
}

model Notification {
  id            String             @id @default(uuid()) @db.Uuid
  bookingId     String?            @map("booking_id") @db.Uuid
  recipientId   String             @map("recipient_id") @db.Uuid
  type          NotificationType
  status        NotificationStatus @default(scheduled)
  scheduledFor  DateTime?          @map("scheduled_for") @db.Timestamptz(6)
  sentAt        DateTime?          @map("sent_at") @db.Timestamptz(6)
  failureReason      String?            @map("failure_reason")
  skipReason         String?            @map("skip_reason")
  depositDisposition String?            @map("deposit_disposition")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  recipient User     @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([bookingId, recipientId, type])
  @@index([status, scheduledFor])
  @@index([bookingId])
  @@map("notifications")
}

/// Per-user notification preferences (Ch.5.4 / Ch.12). No field to disable transactional messages.
model NotificationPreference {
  userId                       String   @id @map("user_id") @db.Uuid
  appointmentRemindersEnabled  Boolean  @default(true) @map("appointment_reminders_enabled")
  marketingMessagesEnabled     Boolean  @default(true) @map("marketing_messages_enabled")
  updatedAt                    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

/// Append-only compliance log for STOP/START and profile preference changes (Ch.12.4).
model OptOutAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  phoneNumber String   @map("phone_number")
  userId      String?  @map("user_id") @db.Uuid
  action      String
  channel     String
  keyword     String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([phoneNumber, createdAt])
  @@index([userId, createdAt])
  @@map("opt_out_audit_log")
}

/// Ch.5.1 / Ch.17.4 — optional client display name (phone remains canonical identity).
model ClientProfile {
  userId      String   @id @map("user_id") @db.Uuid
  displayName String?  @map("display_name")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("client_profiles")
}

/// Ch.5.3 / Ch.17.4 — client saved stylists for quick rebooking.
model SavedStylist {
  clientId  String   @map("client_id") @db.Uuid
  stylistId String   @map("stylist_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client  User           @relation("SavedStylistClient", fields: [clientId], references: [id], onDelete: Cascade)
  stylist StylistProfile @relation(fields: [stylistId], references: [id], onDelete: Cascade)

  @@id([clientId, stylistId])
  @@index([clientId, createdAt])
  @@map("saved_stylists")
}

/// Platform-level SMS preferences (Ch.12.4 — STOP halts AI, not transactional notices).
model SmsPreference {
  phoneNumber         String    @id @map("phone_number")
  aiOptedOut          Boolean   @default(false) @map("ai_opted_out")
  marketingOptedOut   Boolean   @default(false) @map("marketing_opted_out")
  optedOutAt          DateTime? @map("opted_out_at") @db.Timestamptz(6)
  optedInAt           DateTime? @map("opted_in_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("sms_preferences")
}
