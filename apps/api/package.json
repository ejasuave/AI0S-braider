{
  "name": "@project-braids/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "start": "node dist/server.js",
    "worker:start": "node dist/worker.js",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.9.0",
    "@project-braids/shared-types": "workspace:*",
    "@sentry/node": "^9.30.0",
    "bullmq": "^5.53.2",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "pino": "^9.7.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@project-braids/config": "workspace:*",
    "eslint": "^9.28.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
