{
  "name": "@project-braids/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "start": "node dist/server.js",
    "worker:start": "node dist/worker.js",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "receptionist:evaluate": "tsx scripts/evaluate-receptionist-golden-set.ts",
    "receptionist:sample-escalations": "tsx scripts/sample-escalations-for-review.ts",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "db:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/static": "^9.3.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.9.0",
    "@project-braids/shared-types": "workspace:*",
    "@sentry/node": "^9.30.0",
    "bullmq": "^5.53.2",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "pino": "^9.7.0",
    "stripe": "^22.3.0",
    "twilio": "^6.0.2",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@project-braids/config": "workspace:*",
    "eslint": "^9.28.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
