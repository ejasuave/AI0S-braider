{
  "id": "booking-three-turn",
  "type": "functional",
  "description": "Straightforward booking resolved over multiple turns",
  "turns": [
    {
      "mockOutput": {
        "intent": "new_booking",
        "extracted_slots": { "styleName": "Knotless braids" },
