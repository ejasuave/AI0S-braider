# Project Braids API — copy to repo root `.env` (see README) or export these before `pnpm dev`
# Never commit real secrets. Use sandbox/test credentials locally.

# --- Runtime ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
PLATFORM_DISPLAY_NAME=Project Braids
CORS_ORIGIN=http://localhost:3000
WEB_APP_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:3001

# --- Database (Ch.1.4) ---
DATABASE_URL=postgresql://braids:braids@localhost:5432/braids_dev
# Prisma Dev fallback (when Docker unavailable): `pnpm infra:up` prints the URL

# --- Redis (Ch.1.7 — background jobs, rate limits) ---
REDIS_URL=redis://localhost:6379

# --- Auth (Ch.3) ---
JWT_SECRET=local-dev-jwt-secret-min-32-chars-ok
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30
OTP_MAX_REQUESTS_PER_HOUR=5
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=60000

# --- Booking / scheduling ---
BOOKING_HOLD_TTL_MINUTES=15
PLATFORM_TIMEZONE=Europe/London
AVAILABILITY_SLOT_INTERVAL_MINUTES=15
AVAILABILITY_MAX_DAYS=14

# --- Stripe (optional — mock provider when unset) ---
# For live beta: set BOTH secret (API) and publishable (web). See docs/STRIPE_LIVE_SETUP.md
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_CONNECT_RETURN_URL=http://localhost:3000/stylist/payments
# STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/stylist/payments

# --- Twilio SMS (optional — console provider when unset) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+447...

# --- AI receptionist (optional — mock Claude when unset) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# AI_RECEPTIONIST_ENABLED=true
# AI_CONFIDENCE_THRESHOLD=0.8
# AI_RECEPTIONIST_MAX_HISTORY_MESSAGES=12

# --- Messaging rate limits (Ch.13.7) ---
# MESSAGING_RATE_LIMIT_MAX=30
# MESSAGING_RATE_LIMIT_WINDOW_MS=60000

# --- OAuth (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALENDAR_WEBHOOK_SECRET=
# APPLE_CLIENT_ID=

# --- Observability (Ch.1.8 — no-op when unset) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development

# --- Ops (staging/production) ---
# OPS_BEARER_TOKEN=
