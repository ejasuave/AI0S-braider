# Project Braids Web — copy to repo root `.env` alongside API vars (see README)
# Only NEXT_PUBLIC_* variables are exposed to the browser.

# --- Public (client-safe) ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PLATFORM_DISPLAY_NAME=Project Braids
# Required for real card deposits (pk_test_ or pk_live_ — must match API STRIPE_SECRET_KEY mode)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Required for real Google Calendar connect (same client ID as API GOOGLE_CLIENT_ID)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Server-only observability (Ch.1.8 — no-op when unset) ---
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
