# Staging — isolated from production (Ch.23.2)
# Copy to your host / platform secret store. Never use production DB or Stripe live keys.

NODE_ENV=staging
DEPLOY_ENV=staging
PORT=3001
HOST=0.0.0.0

# Separate Supabase project / Postgres instance
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/braids_staging
REDIS_URL=redis://HOST:6379

LOG_LEVEL=info
CORS_ORIGIN=https://staging.example.com
WEB_APP_URL=https://staging.example.com
PLATFORM_DISPLAY_NAME=Project Braids (Staging)

JWT_SECRET=<generate-unique-32+-char-secret>
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_DAYS=30

BOOKING_HOLD_TTL_MINUTES=15
PLATFORM_TIMEZONE=Europe/London

# Stripe TEST mode only
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_RETURN_URL=https://staging.example.com/stylist/payments
STRIPE_CONNECT_REFRESH_URL=https://staging.example.com/stylist/payments

# Twilio test / staging number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+447...
API_PUBLIC_URL=https://api-staging.example.com

# Claude — staging API key
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_RECEPTIONIST_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.8

# Ops (recommended on staging)
GIT_SHA=
APP_VERSION=0.0.0-staging
OPS_BEARER_TOKEN=<generate-ops-token-for-drills>

SENTRY_DSN=
SENTRY_ENVIRONMENT=staging

# Web (Vercel / host)
NEXT_PUBLIC_API_URL=https://api-staging.example.com
NEXT_PUBLIC_PLATFORM_DISPLAY_NAME=Project Braids (Staging)
